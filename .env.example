# Copy to .env.local for local dev. Set these in Vercel's project settings for production.

# ── Cloudflare Turnstile (optional) ──────────────────────────────────────
# Set TURNSTILE_ENABLED=true and both keys to protect the form from bots.
# Get site/secret key pairs at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Cloudflare KV (optional, replaces in‑memory cache) ───────────────
# Set CLOUDFLARE_KV_ENABLED=true and provide your credentials.
# Get your Account ID, Namespace ID, and create an API token with
# "KV Storage" read/write permissions.
CLOUDFLARE_KV_ENABLED=false
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_API_TOKEN=
